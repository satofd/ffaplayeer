<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        x:Class="FFmPlayer.SettingsWindow"
        x:DataType="vm:MainViewModel"
        Title="設定" Width="600" Height="500" Background="#1E1E1E" WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="20">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="10">
                <TextBlock Text="一般設定" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                
                <Grid ColumnDefinitions="200, *" RowDefinitions="Auto, Auto, Auto" Margin="10,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="デフォルト音量 (0-1):" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.Volume}" Margin="0,5"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="メモリ制限 (MB):" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.MemoryLimitMB}" Margin="0,5"/>
                </Grid>

                <TextBlock Text="ショートカットキー設定" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/>
                
                <Grid ColumnDefinitions="200, *" RowDefinitions="Auto, Auto, Auto, Auto" Margin="10,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="再生/一時停止:" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.ShortcutPlayPause}" Margin="0,5"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="停止:" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.ShortcutStop}" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ファイルを開く:" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.ShortcutOpenFile}" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="プレイリスト開閉:" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.ShortcutShowPlaylist}" Margin="0,5"/>
                </Grid>

                <TextBlock x:Name="ErrorTextBlock" Foreground="Red" FontWeight="Bold" Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="キャンセル" Click="OnCancelClick" Width="80" HorizontalContentAlignment="Center"/>
            <Button Content="保存して閉じる" Click="OnSaveClick" Width="120" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
