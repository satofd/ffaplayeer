<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        x:Class="FFmPlayer.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FFmPlayer"
        Background="#1E1E1E"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        DragDrop.AllowDrop="True">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#252526" Height="30" PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="FFmPlayer" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                </StackPanel>
                
                <!-- Title + Playlist Left Aligned -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="{Binding CurrentPlaylistItem}" Foreground="LightGray" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                    <TextBlock Text="{Binding CurrentPlaylistIndex, StringFormat='{} [{0} / '}" Foreground="Gray" VerticalAlignment="Center" IsVisible="{Binding CurrentPlaylistIndex, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <TextBlock Text="{Binding Playlist.Count, StringFormat='{}{0}]'}" Foreground="Gray" VerticalAlignment="Center" IsVisible="{Binding CurrentPlaylistIndex, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
                    <Button Content="-" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnMinimizeClick"/>
                    <Button Content="□" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnMaximizeClick"/>
                    <Button Content="×" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnCloseClick"/>
                    <StackPanel.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#3E3E40"/>
                        </Style>
                    </StackPanel.Styles>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Video Area with Context Menu -->
        <Border Grid.Row="1" Background="Black">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="設定 (Settings)" Command="{Binding OpenSettingsCommand}"/>
                    <MenuItem Header="プレイリスト" Command="{Binding OpenPlaylistCommand}"/>
                </ContextMenu>
            </Border.ContextMenu>
            <Grid>
                <Image x:Name="VideoImage" Stretch="Uniform" Source="{Binding VideoFrameBitmap}" />
                <!-- OSD Message overlapping video -->
                <TextBlock Text="{Binding OsdMessage}" Foreground="White" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"
                           IsVisible="{Binding OsdVisible}">
                    <TextBlock.Effect>
                        <DropShadowDirectionEffect ShadowDepth="2" BlurRadius="4" Color="Black" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Controls Area -->
        <StackPanel Grid.Row="2" Background="#2D2D30" Orientation="Vertical">
            <!-- Seek Bar -->
            <Slider Minimum="0" Maximum="{Binding Duration}" Value="{Binding Position}" PointerCaptureLost="OnSliderPointerCaptureLost" Margin="10,0"/>
            
            <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="5">
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Content="-60s" Command="{Binding SeekBackward60Command}" Width="40" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="-10s" Command="{Binding SeekBackward10Command}" Width="40" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="-1s" Command="{Binding SeekBackward1Command}" Width="35" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="&lt; F" Command="{Binding StepBackwardCommand}" Width="35" HorizontalContentAlignment="Center" FontSize="11"/>
                    
                    <Button Content="Play" Command="{Binding PlayPauseCommand}" Margin="5,0"/>
                    <Button Content="Stop" Command="{Binding StopCommand}" Margin="0,0,5,0"/>

                    <Button Content="F &gt;" Command="{Binding StepForwardCommand}" Width="35" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="+1s" Command="{Binding SeekForward1Command}" Width="35" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="+10s" Command="{Binding SeekForward10Command}" Width="40" HorizontalContentAlignment="Center" FontSize="11"/>
                    <Button Content="+60s" Command="{Binding SeekForward60Command}" Width="40" HorizontalContentAlignment="Center" FontSize="11"/>

                    <!-- Time Display -->
                    <StackPanel Orientation="Horizontal" Margin="10,0,5,0" VerticalAlignment="Center">
                        <TextBlock Foreground="White" Text="{Binding TimePosition, StringFormat={}{0:hh\\:mm\\:ss}}" FontSize="12"/>
                        <TextBlock Foreground="White" Text=" / " FontSize="12"/>
                        <TextBlock Foreground="White" Text="{Binding TimeDuration, StringFormat={}{0:hh\\:mm\\:ss}}" FontSize="12"/>
                        <TextBlock Foreground="White" Text=" (-" FontSize="12"/>
                        <TextBlock Foreground="White" Text="{Binding TimeRemaining, StringFormat={}{0:hh\\:mm\\:ss}}" FontSize="12"/>
                        <TextBlock Foreground="White" Text=") | フレーム: " FontSize="12"/>
                        <TextBlock Foreground="White" Text="{Binding CurrentFrame}" FontSize="12"/>
                        <TextBlock Foreground="White" Text=" / " FontSize="12"/>
                        <TextBlock Foreground="White" Text="{Binding MaxFrame}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Content="-" Command="{Binding DecreaseSpeedCommand}" Width="25" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:F2}x}" Foreground="White" VerticalAlignment="Center" Width="35" TextAlignment="Center" FontSize="12"/>
                    <Button Content="+" Command="{Binding IncreaseSpeedCommand}" Width="25" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center" Margin="15,0,5,0">
                    <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" Width="70" />
                    <CheckBox Content="Mute" IsChecked="{Binding IsMuted}" Foreground="White" FontSize="12"/>
                    <Button Content="Full" Click="OnFullscreenToggleClick" Margin="5,0,0,0" FontSize="12"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
