<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        x:Class="FFmPlayer.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FFmPlayer"
        Background="#1E1E1E"
        WindowDecorations="None"
        Topmost="{Binding AlwaysOnTop}"
        DragDrop.AllowDrop="True">

    <Window.Styles>
        <!-- Icon Buttons Style -->
        <Style Selector="Button.IconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.IconBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="Button.IconBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#55FFFFFF"/>
        </Style>

        <Style Selector="ToggleButton.IconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="ToggleButton.IconBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="ToggleButton.IconBtn:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
        </Style>
        <Style Selector="ToggleButton.IconBtn:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#44FFFFFF"/>
        </Style>
    </Window.Styles>

    <!-- Resize Handles wrapped around the main Grid -->
    <Grid>
        <!-- Main Layout -->
        <Grid RowDefinitions="Auto, *, Auto" Margin="4">
            
            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#252526" Height="30" PointerPressed="OnTitleBarPointerPressed">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                        <TextBlock Text="FFmPlayer" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    </StackPanel>
                    
                    <!-- Title + Playlist Left Aligned -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="10" IsVisible="{Binding IsMediaActive}">
                        <TextBlock Text="{Binding CurrentPlaylistItem}" Foreground="LightGray" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                        <TextBlock Text="{Binding CurrentPlaylistIndex, StringFormat='{} [{0} / '}" Foreground="Gray" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Playlist.Count, StringFormat='{}{0}]'}" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0">
                        <Button Content="-" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnMinimizeClick"/>
                        <Button Content="□" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnMaximizeClick"/>
                        <Button Content="×" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Video Area with Context Menu and Mouse wheel/click handling -->
            <Border Grid.Row="1" Background="Black" PointerWheelChanged="OnVideoPointerWheelChanged" PointerPressed="OnVideoPointerPressed" DoubleTapped="OnVideoDoubleTapped">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="ファイルを開く (Open File)" Command="{Binding OpenFileCommand}"/>
                        <MenuItem Header="連番画像を開く (Open Image Sequence)" Command="{Binding OpenImageSequenceCommand}"/>
                        <MenuItem Header="URLを開く (Open URL)" Command="{Binding OpenUrlCommand}"/>
                        <MenuItem Header="プロパティ (Media Info)" Command="{Binding ShowMediaInfoCommand}"/>
                        <MenuItem Header="設定 (Settings)" Command="{Binding OpenSettingsCommand}"/>
                        <MenuItem Header="プレイリスト" Command="{Binding OpenPlaylistCommand}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Image x:Name="VideoImage" Stretch="{Binding VideoStretch}" Source="{Binding VideoFrameBitmap}" />
                    <!-- OSD Message overlapping video -->
                    <TextBlock Text="{Binding OsdMessage}" Foreground="White" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20"
                               IsVisible="{Binding OsdVisible}">
                        <TextBlock.Effect>
                            <DropShadowDirectionEffect ShadowDepth="2" BlurRadius="4" Color="Black" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Controls Area -->
            <StackPanel Grid.Row="2" Background="#2D2D30" Orientation="Vertical">
                <!-- Seek Bar -->
                <Slider x:Name="SeekSlider" Minimum="0" Maximum="{Binding Duration}" Value="{Binding Position}" Margin="10,0"/>
                
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="5">
                    
                    <!-- Left: Play, Stop, Prev, Next, Mute, Vol Slider, Vol Text, Position/Duration -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        
                        <Button Classes="IconBtn" Command="{Binding PlayPauseCommand}" Width="30" Height="30" Padding="5">
                            <Viewbox Stretch="Uniform" Margin="2,0,0,0">
                                <Path Data="M 0 0 L 12 7 L 0 14 Z" Fill="White"/>
                            </Viewbox>
                        </Button>
                        <Button Classes="IconBtn" Command="{Binding StopCommand}" Width="30" Height="30" Padding="5">
                            <Viewbox Stretch="Uniform" Margin="2">
                                <Path Data="M 0 0 H 12 V 12 H 0 Z" Fill="White"/>
                            </Viewbox>
                        </Button>
                        <Button Classes="IconBtn" Command="{Binding PlayListPrevCommand}" Width="30" Height="30" Padding="5" ToolTip.Tip="前のプレイリスト">
                            <Viewbox Stretch="Uniform">
                                <Path Data="M 12 0 L 2 7 L 12 14 Z M 0 0 H 2 V 14 H 0 Z" Fill="White"/>
                            </Viewbox>
                        </Button>
                        <Button Classes="IconBtn" Command="{Binding PlayListNextCommand}" Width="30" Height="30" Padding="5" ToolTip.Tip="次のプレイリスト">
                            <Viewbox Stretch="Uniform">
                                <Path Data="M 0 0 L 10 7 L 0 14 Z M 10 0 H 12 V 14 H 10 Z" Fill="White"/>
                            </Viewbox>
                        </Button>
                        
                        <!-- Volume & Mute -->
                        <ToggleButton Classes="IconBtn" IsChecked="{Binding IsMuted}" Width="30" Height="30" Padding="5" Margin="10,0,0,0" ToolTip.Tip="ミュート">
                            <Grid>
                                <Viewbox Stretch="Uniform">
                                    <Path Data="M 0 4 L 4 4 L 9 0 L 9 14 L 4 10 L 0 10 Z" Fill="White"/>
                                </Viewbox>
                                <!-- X mark overlay -->
                                <Viewbox Stretch="Uniform" IsVisible="{Binding IsMuted}" Margin="2">
                                    <Path Data="M 12 2 L 10 0 L 6 4 L 2 0 L 0 2 L 4 6 L 0 10 L 2 12 L 6 8 L 10 12 L 12 10 L 8 6 Z" Fill="#FF4444"/>
                                </Viewbox>
                            </Grid>
                        </ToggleButton>
                        <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" Width="70" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Volume, StringFormat={}{0:P0}}" Foreground="White" Width="35" TextAlignment="Right" VerticalAlignment="Center"/>

                        <!-- Time Display -->
                        <TextBlock Foreground="White" Text="{Binding TimeDisplayText}" FontSize="12" Margin="15,0,5,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Right: from right to left (Speed text, Speed slider, Control panel, Settings) -->
                    <!-- Wait, right from right to left means Settings is rightmost, ControlPanel is to its left, then speed text, then speed slider. So reading left to right inside the right panel: Speed Slider, Speed Text, Control Panel, Settings -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,5,0">
                        <!-- Speed -->
                        <Slider Minimum="0.1" Maximum="3.0" Value="{Binding PlaybackSpeed}" Width="70" VerticalAlignment="Center"/>
                        <Button BorderThickness="0" Background="Transparent" Padding="0" Cursor="Hand" ToolTip.Tip="クリックで1.0xにリセット" Command="{Binding ResetSpeedCommand}">
                            <TextBlock Text="{Binding PlaybackSpeed, StringFormat={}{0:F2}x}" Foreground="White" VerticalAlignment="Center" Width="35" TextAlignment="Center" FontSize="12"/>
                        </Button>

                        <!-- Playlist Btn -->
                        <Button Classes="IconBtn" Command="{Binding OpenPlaylistCommand}" Width="30" Height="30" Padding="0" ToolTip.Tip="プレイリスト">
                            <TextBlock Text="☰" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Control Panel Btn -->
                        <Button Classes="IconBtn" Command="{Binding OpenControlPanelCommand}" Width="30" Height="30" Padding="5" ToolTip.Tip="コントロールパネル">
                            <Viewbox Stretch="Uniform">
                                <Path Data="M 0 3 H 14 V 5 H 0 Z M 3 1 H 6 V 7 H 3 Z M 0 9 H 14 V 11 H 0 Z M 8 7 H 11 V 13 H 8 Z" Fill="White"/>
                            </Viewbox>
                        </Button>
                        
                        <!-- Settings Btn -->
                        <Button Classes="IconBtn" Command="{Binding OpenSettingsCommand}" Width="30" Height="30" Padding="0" ToolTip.Tip="設定">
                            <TextBlock Text="⚙" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Resize Grips (transparent margins over the window) -->
        <Border Width="4" HorizontalAlignment="Left" Cursor="LeftSide" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="West"/>
        <Border Width="4" HorizontalAlignment="Right" Cursor="RightSide" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="East"/>
        <Border Height="4" VerticalAlignment="Top" Cursor="TopSide" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="North"/>
        <Border Height="4" VerticalAlignment="Bottom" Cursor="BottomSide" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="South"/>
        
        <!-- Corners -->
        <Border Width="6" Height="6" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="TopLeftCorner" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="NorthWest"/>
        <Border Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="TopRightCorner" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="NorthEast"/>
        <Border Width="6" Height="6" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="BottomLeftCorner" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="SouthWest"/>
        <Border Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="BottomRightCorner" Background="Transparent" PointerPressed="OnResizePointerPressed" Tag="SouthEast"/>
    </Grid>
</Window>
