<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FFmPlayer.MediaInfoWindow"
        Title="メディア情報" Width="400" Height="300" WindowStartupLocation="CenterOwner" Background="#1E1E1E">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="メディア情報" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
        <ScrollViewer Height="180">
            <TextBlock x:Name="InfoTextBlock" Foreground="LightGray" TextWrapping="Wrap" />
        </ScrollViewer>
        <Button Content="閉じる" Click="OnCloseClick" HorizontalAlignment="Right" Background="#333333" Foreground="White" Width="80" HorizontalContentAlignment="Center"/>
    </StackPanel>
</Window>
