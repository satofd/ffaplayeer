<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        x:Class="FFmPlayer.PlaylistWindow"
        x:DataType="vm:MainViewModel"
        Title="プレイリスト" Width="400" Height="600" Background="#1E1E1E" WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="プレイリスト" FontSize="20" FontWeight="Bold" Foreground="White" Margin="10"/>
        
        <ListBox x:Name="PlaylistListBox" Grid.Row="1" ItemsSource="{Binding Playlist}" SelectedItem="{Binding CurrentPlaylistItem}" Margin="10" Background="#2D2D30">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
