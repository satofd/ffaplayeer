<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        xmlns:models="using:FFmPlayer.Models"
        x:Class="FFmPlayer.PlaylistWindow"
        x:DataType="vm:MainViewModel"
        Title="プレイリスト" Width="450" Height="600" Background="#1E1E1E" WindowStartupLocation="CenterOwner"
        DragDrop.AllowDrop="True">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="10" Spacing="10">
            <TextBlock Text="プレイリスト" FontSize="20" FontWeight="Bold" Foreground="White" />
            <Grid ColumnDefinitions="*,Auto">
                <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" SelectedItem="{Binding Settings.PlaybackMode}" Foreground="White" Margin="0,0,10,0">
                    <models:PlaybackMode>Sequential</models:PlaybackMode>
                    <models:PlaybackMode>RepeatOne</models:PlaybackMode>
                    <models:PlaybackMode>Random</models:PlaybackMode>
                    <models:PlaybackMode>Off</models:PlaybackMode>
                </ComboBox>
                <Button Grid.Column="1" Content="ファイル追加" Click="OnAddFilesClick" Width="100" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White"/>
            </Grid>
        </StackPanel>
        
        <ListBox x:Name="PlaylistListBox" Grid.Row="1" ItemsSource="{Binding Playlist}" SelectedItem="{Binding CurrentPlaylistItem}" Margin="10" Background="#2D2D30">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="削除" Click="OnRemoveItemClick" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
