<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FFmPlayer.ViewModels"
        x:Class="FFmPlayer.ControlPanelWindow"
        x:DataType="vm:MainViewModel"
        Title="コントロールパネル" Width="400" Height="150" 
        Background="#2D2D30" WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True" WindowDecorations="None"
        CanResize="False" Topmost="True">
    
    <Window.Styles>
        <Style Selector="Button.ControlBtn">
            <Setter Property="Background" Value="#3E3E42" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style Selector="Button.ControlBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#55555A"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#252526" Height="30" PointerPressed="OnTitleBarPointerPressed">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <TextBlock Grid.Column="0" Text="コントロールパネル" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
                <Button Grid.Column="2" Content="×" Width="40" Background="Transparent" Foreground="White" BorderThickness="0" CornerRadius="0" HorizontalContentAlignment="Center" Click="OnCloseClick">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#3E3E40"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="*,*" Margin="15">
        
        <!-- Backward row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Classes="ControlBtn" Content="-60s" Command="{Binding SeekBackward60Command}"/>
            <Button Classes="ControlBtn" Content="-10s" Command="{Binding SeekBackward10Command}"/>
            <Button Classes="ControlBtn" Content="-1s" Command="{Binding SeekBackward1Command}"/>
            <Button Classes="ControlBtn" Content="&lt; F" Command="{Binding StepBackwardCommand}" ToolTip.Tip="コマ戻し"/>
        </StackPanel>

        <!-- Forward row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Classes="ControlBtn" Content="+60s" Command="{Binding SeekForward60Command}"/>
            <Button Classes="ControlBtn" Content="+10s" Command="{Binding SeekForward10Command}"/>
            <Button Classes="ControlBtn" Content="+1s" Command="{Binding SeekForward1Command}"/>
            <Button Classes="ControlBtn" Content="F &gt;" Command="{Binding StepForwardCommand}" ToolTip.Tip="コマ送り"/>
        </StackPanel>
        
        </Grid>
    </Grid>
</Window>
