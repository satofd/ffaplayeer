<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FFmPlayer.UrlInputDialog"
        Title="URLを開く" Width="400" Height="150" WindowStartupLocation="CenterOwner" Background="#1E1E1E">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="メディアURLを入力してください：" Foreground="White"/>
        <TextBox x:Name="UrlTextBox" PlaceholderText="http://..." Foreground="White" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="キャンセル" Click="OnCancelClick" Background="#333333" Foreground="White" Width="80" HorizontalContentAlignment="Center"/>
            <Button Content="開く" Click="OnOpenClick" Background="#007ACC" Foreground="White" Width="80" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</Window>
